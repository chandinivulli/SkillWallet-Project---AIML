:root {
  --bg: #101d33;
  --surface: #17263f;
  --surface-2: #1e304d;
  --accent: #e0a458;
  --accent-soft: rgba(224, 164, 88, 0.16);
  --text: #eef2f7;
  --muted: #93a4bf;
  --border: rgba(147, 164, 191, 0.18);
  --low: #d16a5a;
  --medium: #e0a458;
  --high: #7fb08a;
  --veryhigh: #4f9d8e;
}

* { box-sizing: border-box; }

body {
  margin: 0;
  background: var(--bg);
  background-image:
    radial-gradient(circle at 15% 0%, rgba(224, 164, 88, 0.08), transparent 40%),
    radial-gradient(circle at 85% 100%, rgba(79, 157, 142, 0.10), transparent 45%);
  color: var(--text);
  font-family: 'Inter', -apple-system, sans-serif;
  min-height: 100vh;
}

.page {
  max-width: 720px;
  margin: 0 auto;
  padding: 64px 24px 40px;
}

.hero { margin-bottom: 36px; }
.hero--result { margin-bottom: 28px; }

.eyebrow {
  display: inline-block;
  font-family: 'IBM Plex Mono', monospace;
  font-size: 12px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--accent);
  border: 1px solid rgba(224, 164, 88, 0.35);
  padding: 5px 12px;
  border-radius: 100px;
  margin-bottom: 20px;
}

h1 {
  font-family: 'Fraunces', serif;
  font-weight: 600;
  font-size: 42px;
  line-height: 1.08;
  margin: 0 0 16px;
  letter-spacing: -0.01em;
}

.lede {
  color: var(--muted);
  font-size: 16px;
  line-height: 1.6;
  max-width: 56ch;
  margin: 0;
}

.panel {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 36px;
}

.error-banner {
  background: rgba(209, 106, 90, 0.15);
  border: 1px solid rgba(209, 106, 90, 0.4);
  color: #f0c3ba;
  padding: 12px 16px;
  border-radius: 10px;
  font-size: 14px;
  margin-bottom: 24px;
}

.form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 22px 20px;
}

.field { display: flex; flex-direction: column; }

.field label {
  font-size: 13.5px;
  font-weight: 600;
  margin-bottom: 8px;
  color: var(--text);
}
.field label span {
  font-family: 'IBM Plex Mono', monospace;
  font-weight: 400;
  color: var(--muted);
  font-size: 11.5px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-left: 6px;
}

.field input {
  background: var(--surface-2);
  border: 1px solid var(--border);
  border-radius: 10px;
  color: var(--text);
  font-family: 'IBM Plex Mono', monospace;
  font-size: 15px;
  padding: 12px 14px;
  outline: none;
  transition: border-color 0.15s ease;
}
.field input:focus {
  border-color: var(--accent);
}
.field input::placeholder { color: #56658066; }

.hint {
  font-size: 12px;
  color: var(--muted);
  margin: 7px 2px 0;
  line-height: 1.4;
}

.submit-btn {
  grid-column: 1 / -1;
  margin-top: 6px;
  background: var(--accent);
  color: #1a1206;
  border: none;
  border-radius: 10px;
  padding: 14px 20px;
  font-family: 'Inter', sans-serif;
  font-weight: 600;
  font-size: 15px;
  cursor: pointer;
  text-align: center;
  text-decoration: none;
  display: inline-block;
  transition: transform 0.12s ease, box-shadow 0.12s ease;
}
.submit-btn:hover {
  transform: translateY(-1px);
  box-shadow: 0 8px 24px rgba(224, 164, 88, 0.25);
}
.submit-btn.secondary {
  background: transparent;
  color: var(--accent);
  border: 1px solid rgba(224, 164, 88, 0.4);
  margin-top: 28px;
}

.result-panel { text-align: left; }

.score-block { text-align: center; margin-bottom: 30px; }
.score-number {
  font-family: 'Fraunces', serif;
  font-size: 64px;
  font-weight: 600;
  color: var(--accent);
  line-height: 1;
}
.score-scale {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 12px;
  color: var(--muted);
  margin-top: 8px;
}

.tier-badge {
  display: inline-block;
  margin-top: 16px;
  padding: 6px 16px;
  border-radius: 100px;
  font-size: 13px;
  font-weight: 600;
}
.tier-low       { background: rgba(209, 106, 90, 0.16); color: var(--low); }
.tier-medium    { background: rgba(224, 164, 88, 0.16); color: var(--medium); }
.tier-high      { background: rgba(127, 176, 138, 0.16); color: var(--high); }
.tier-very-high { background: rgba(79, 157, 142, 0.18); color: var(--veryhigh); }

.gauge { margin: 28px 0 34px; }
.gauge-track {
  position: relative;
  display: flex;
  height: 10px;
  border-radius: 6px;
  overflow: visible;
}
.gauge-segment { flex: 1; }
.seg-low { background: var(--low); border-radius: 6px 0 0 6px; }
.seg-medium { background: var(--medium); }
.seg-high { background: var(--high); }
.seg-veryhigh { background: var(--veryhigh); border-radius: 0 6px 6px 0; }

.gauge-marker {
  position: absolute;
  top: -5px;
  width: 3px;
  height: 20px;
  background: #ffffff;
  border-radius: 2px;
  box-shadow: 0 0 0 3px rgba(255,255,255,0.15);
  transform: translateX(-50%);
}

.gauge-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 10px;
  font-family: 'IBM Plex Mono', monospace;
  font-size: 11px;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 0.04em;
}

.inputs-title {
  font-family: 'Fraunces', serif;
  font-size: 18px;
  font-weight: 600;
  margin: 0 0 12px;
  color: var(--text);
}

.inputs-table {
  width: 100%;
  border-collapse: collapse;
  margin-bottom: 8px;
}
.inputs-table td {
  padding: 10px 0;
  border-bottom: 1px solid var(--border);
  font-size: 14px;
}
.inputs-table td:first-child { color: var(--muted); }
.inputs-table td:last-child {
  text-align: right;
  font-family: 'IBM Plex Mono', monospace;
  color: var(--text);
}

.footer {
  margin-top: 32px;
  text-align: center;
  font-family: 'IBM Plex Mono', monospace;
  font-size: 11.5px;
  color: var(--muted);
  opacity: 0.7;
}

@media (max-width: 560px) {
  .form-grid { grid-template-columns: 1fr; }
  h1 { font-size: 32px; }
  .score-number { font-size: 48px; }
}
